{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run preview)",
      "Bash(npm ci)",
      "Bash(terraform init:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform fmt:*)",
      "Bash(go test:*)",
      "Bash(make build-lambdas)",
      "Bash(make build-email-parser)",
      "Bash(make build-api-handler)"
    ],
    "deny": [
      "Bash(make deploy:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint 2>&1 | tail -20"
          }
        ]
      }
    ]
  }
}
